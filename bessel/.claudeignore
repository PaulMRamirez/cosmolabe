# .claudeignore
# Files Claude Code will not read or modify during sessions.

# Secrets and credentials
.env
.env.*
*.pem
*.key
secrets/

# Large or non-redistributable SPICE kernel data (fixtures under kernels/ that
# are small and redistributable are allowed; the bulk data is fetched, not committed)
kernels/data/
*.bsp
*.bpc
*.bc
*.tpc
*.tf
*.ti
*.tls
*.tsc
*.dsk

# Build and dependency output
node_modules/
dist/
out/
.vite/
apps/desktop/out/
apps/mobile/ios/
apps/mobile/android/

# Generated native projects (regenerated by cap add / cap sync)
ios/
android/
