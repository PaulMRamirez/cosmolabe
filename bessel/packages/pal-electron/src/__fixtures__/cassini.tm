KPL/MK

   A meta-kernel fixture with relative paths, mirroring the desktop Cosmographia
   layout. Resolution substitutes the symbols and resolves against this file.

\begindata

   PATH_VALUES  = ( 'lsk', 'spk' )
   PATH_SYMBOLS = ( 'LSK', 'SPK' )
   KERNELS_TO_LOAD = ( '$LSK/leap.tls',
                       '$SPK/de.bsp' )

