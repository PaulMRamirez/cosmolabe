{
  "name": "cspice-wasm",
  "description": "NAIF CSPICE compiled to WebAssembly with a typed full-surface wrapper, worker pool, and zero-copy batch API; extracted from bessel's spice layer per ADR M-0002 (the npm name is reserved; this workspace package is the internal publication)",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "development": "./src/worker.ts",
      "import": "./dist/worker.js"
    },
    "./worker-core": {
      "types": "./dist/worker-core.d.ts",
      "development": "./src/worker-core.ts",
      "import": "./dist/worker-core.js"
    },
    "./wasm/cspice.mjs": "./wasm/cspice.mjs",
    "./wasm/cspice.wasm": "./wasm/cspice.wasm"
  },
  "types": "./dist/index.d.ts"
}
