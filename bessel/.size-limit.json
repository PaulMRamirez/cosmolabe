[
  {
    "name": "web app shell (first-paint JS, gzip)",
    "path": [
      "apps/web/dist/assets/app-*.js",
      "apps/web/dist/assets/vendor-*.js"
    ],
    "limit": "345 KB",
    "gzip": true
  },
  {
    "name": "lazy analysis bundle (gzip)",
    "path": [
      "apps/web/dist/assets/*.js",
      "!apps/web/dist/assets/app-*.js",
      "!apps/web/dist/assets/vendor-*.js",
      "!apps/web/dist/assets/spice.worker-*.js",
      "!apps/web/dist/assets/coverage.worker-*.js",
      "!apps/web/dist/assets/porkchop.worker-*.js",
      "!apps/web/dist/assets/compute.worker-*.js",
      "!apps/web/dist/assets/ajv-lazy-*.js",
      "!apps/web/dist/assets/embed-*.js",
      "!apps/web/dist/assets/mmgis-*.js",
      "!apps/web/dist/assets/fixture-compute-*.js"
    ],
    "limit": "107 KB",
    "gzip": true
  },
  {
    "name": "panel host shared chunk (rollup names it fixture-compute, gzip)",
    "path": "apps/web/dist/assets/fixture-compute-*.js",
    "limit": "8 KB",
    "gzip": true
  },
  {
    "name": "embed host entry (panel mount, gzip)",
    "path": "apps/web/dist/assets/embed-*.js",
    "limit": "8 KB",
    "gzip": true
  },
  {
    "name": "mmgis fixture host entry (gzip)",
    "path": "apps/web/dist/assets/mmgis-*.js",
    "limit": "8 KB",
    "gzip": true
  },
  {
    "name": "coverage worker (gzip)",
    "path": "apps/web/dist/assets/coverage.worker-*.js",
    "limit": "12 KB",
    "gzip": true
  },
  {
    "name": "porkchop worker (gzip)",
    "path": "apps/web/dist/assets/porkchop.worker-*.js",
    "limit": "5 KB",
    "gzip": true
  },
  {
    "name": "catalog validation (ajv, lazy)",
    "path": "apps/web/dist/assets/ajv-lazy-*.js",
    "limit": "46 KB",
    "gzip": true
  },
  {
    "name": "spice worker (gzip)",
    "path": "apps/web/dist/assets/spice.worker-*.js",
    "limit": "32 KB",
    "gzip": true
  },
  {
    "name": "compute worker (gzip)",
    "path": "apps/web/dist/assets/compute.worker-*.js",
    "limit": "36 KB",
    "gzip": true
  },
  {
    "name": "CSPICE WASM (lazy loaded)",
    "path": "apps/web/dist/**/*.wasm",
    "limit": "4 MB"
  }
]
