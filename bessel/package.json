{
  "name": "bessel",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "bench": "vitest bench --run",
    "build:web": "pnpm --filter @bessel/web build",
    "build:pages": "BESSEL_BASE=/bessel/ pnpm --filter @bessel/web build",
    "build:desktop": "pnpm --filter @bessel/desktop build",
    "build:cli": "pnpm --filter @bessel/cli build",
    "cap:sync": "pnpm --filter @bessel/mobile sync",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "size": "size-limit",
    "audit:prod": "pnpm audit --prod --audit-level high",
    "lhci": "lhci autorun",
    "release:dry": "changeset status --verbose",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm build:web && pnpm size",
    "cspice:build": "bash packages/cspice-wasm/scripts/build-cspice.sh"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.17.0",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.49.1",
    "@size-limit/file": "^11.1.6",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "size-limit": "^11.1.6",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
