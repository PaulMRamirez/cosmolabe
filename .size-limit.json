[
  {
    "name": "web app shell (first-paint JS, gzip)",
    "path": ["apps/web/dist/assets/app-*.js", "apps/web/dist/assets/vendor-*.js"],
    "limit": "310 KB",
    "gzip": true
  },
  {
    "name": "lazy analysis bundle (gzip)",
    "path": [
      "apps/web/dist/assets/*.js",
      "!apps/web/dist/assets/app-*.js",
      "!apps/web/dist/assets/vendor-*.js",
      "!apps/web/dist/assets/spice.worker-*.js"
    ],
    "limit": "48 KB",
    "gzip": true
  },
  {
    "name": "spice worker (gzip)",
    "path": "apps/web/dist/assets/spice.worker-*.js",
    "limit": "23 KB",
    "gzip": true
  },
  {
    "name": "CSPICE WASM (lazy loaded)",
    "path": "apps/web/dist/**/*.wasm",
    "limit": "4 MB"
  }
]
