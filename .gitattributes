# git-lfs tiering.
#
# Extensions below are reliably large in this repo (kernels, GPU textures,
# spacecraft .glb meshes), so route them through LFS. Mixed-size formats
# (.png/.jpg/.obj/.cmod/.gltf) are NOT LFS-routed by default — most files in
# those formats are small enough that LFS is overhead. Specific large files
# in those formats get explicit path rules at the bottom of this file.
#
# When adding a new asset:
#   - If the format is reliably > ~1 MB, prefer adding the extension here.
#   - If the format is variable-size, leave it as a regular blob and add a
#     path rule only if the specific file is multi-MB.

# Always-large data formats
*.bsp filter=lfs diff=lfs merge=lfs -text
*.bc filter=lfs diff=lfs merge=lfs -text
*.bpc filter=lfs diff=lfs merge=lfs -text
*.tif filter=lfs diff=lfs merge=lfs -text
*.gz filter=lfs diff=lfs merge=lfs -text
*.wasm filter=lfs diff=lfs merge=lfs -text

# GPU-compressed textures (DXT) — ~1–6 MB each, consistently
*.dds filter=lfs diff=lfs merge=lfs -text

# Spacecraft 3D meshes — ISS_stationary.glb (42 MB), clipper_spacecraft.glb (34 MB), etc.
*.glb filter=lfs diff=lfs merge=lfs -text

# Specific large textures that would otherwise commit as regular blobs.
# (Most .jpg/.png in this repo are body cylindrical maps under 2 MB and stay as regular blobs.)
apps/viewer/test-catalogs/textures/moon-16k.jpg filter=lfs diff=lfs merge=lfs -text
apps/viewer/test-catalogs/textures/moon-displacement-16k.jpg filter=lfs diff=lfs merge=lfs -text
apps/viewer/test-catalogs/textures/moon-normal-16k.jpg filter=lfs diff=lfs merge=lfs -text
