$VK/msl/msl_surf_rover_loc_0000_2003_v1.bsp|7d351e251845bda6368da4a94d547c28b4bd7f4d12db0ac36cb3a1730a12d6cf|$MSL/spk/msl_surf_rover_loc_0000_2003_v1.bsp|apps/viewer/test-catalogs/kernels/msl/msl_surf_rover_loc_0000_2003_v1.bsp|1|demo
$VK/msl/msl_surf_rover_tlm_0449_0583_v1.bsp|635760c093c736661479cc1a6862cb7058d6566a646ed2e36ab0ec9bf060b0ff|$MSL/spk/msl_surf_rover_tlm_0449_0583_v1.bsp|apps/viewer/test-catalogs/kernels/msl/msl_surf_rover_tlm_0449_0583_v1.bsp|1|demo
$VK/msl/msl_surf_rover_tlm_0449_0583_v1.bc|77f39b4bca8299dff3115a912fd0dc55b3428a15631fa3883b1b94331006f7db|$MSL/ck/msl_surf_rover_tlm_0449_0583_v1.bc|apps/viewer/test-catalogs/kernels/msl/msl_surf_rover_tlm_0449_0583_v1.bc|1|demo
EOF
)

# ── helpers ──────────────────────────────────────────────────────────────────

sha_of() { shasum -a 256 "$1" | cut -d' ' -f1; }

# Materialize the git LFS object for a tag path into $2, keyed by its OID ($3).
# If the object is not already in the local LFS store, pull just that one object
# from the git remote at the tag: `git lfs fetch <remote> <ref> --include`. The
# remote name is whatever this clone uses (origin under actions/checkout).
from_lfs() {
  local tagpath="$1" dest="$2" oid="$3"
  local gitdir obj remote
  gitdir="$(git rev-parse --git-dir 2>/dev/null || echo .git)"
  obj="$gitdir/lfs/objects/${oid:0:2}/${oid:2:2}/${oid}"
  if [ ! -f "$obj" ]; then
    remote="$(git remote | grep -m1 . || echo origin)"
    git lfs fetch "$remote" "$TAG" --include="$tagpath" >/dev/null 2>&1 || return 1
  fi
  [ -f "$obj" ] || return 1
  cp "$obj" "$dest"
}

# ── fetch loop ───────────────────────────────────────────────────────────────

fetched=0 skipped=0 failed=0
while IFS='|' read -r dest sha url tagpath lfs scope; do
  [ -n "${dest:-}" ] || continue
  if [ "$scope" = "demo" ] && [ "$FETCH_ALL" -eq 0 ]; then continue; fi

  if [ "$FORCE" -eq 0 ] && [ -f "$dest" ] && [ "$(sha_of "$dest")" = "$sha" ]; then
    skipped=$((skipped + 1)); continue
  fi

  mkdir -p "$(dirname "$dest")"
  tmp="${dest}.part"
  ok=0

  # 1. public URL (the intended path)
  if [ "$url" != "-" ]; then
    if curl -fSL --retry 3 --retry-delay 2 --max-time 600 "$url" -o "$tmp" 2>/dev/null \
       && [ "$(sha_of "$tmp")" = "$sha" ]; then
      mv "$tmp" "$dest"; ok=1
    else
      rm -f "$tmp"
    fi
  fi

  # 2. LFS object (binaries pruned from public archives, e.g. de425s.bsp)
  if [ "$ok" -eq 0 ] && [ "$lfs" = "1" ]; then
    if from_lfs "$tagpath" "$tmp" "$sha" && [ "$(sha_of "$tmp")" = "$sha" ]; then
      mv "$tmp" "$dest"; ok=1
    else
      rm -f "$tmp"
    fi
  fi

  # 3. git tag blob (text kernels and the synthetic test fixture)
  if [ "$ok" -eq 0 ] && [ "$tagpath" != "-" ] && [ "$lfs" = "0" ]; then
    if git cat-file -p "$TAG:$tagpath" > "$tmp" 2>/dev/null \
       && [ "$(sha_of "$tmp")" = "$sha" ]; then
      mv "$tmp" "$dest"; ok=1
    else
      rm -f "$tmp"
    fi
  fi

  if [ "$ok" -eq 1 ]; then
    echo "  [ok]   $dest"
    fetched=$((fetched + 1))
  else
    echo "  [FAIL] $dest (no source produced sha256 $sha)" >&2
    failed=$((failed + 1))
  fi
done <<< "$MANIFEST"

echo ""
echo "fetch-kernels: $fetched fetched, $skipped up-to-date, $failed failed."
if [ "$FETCH_ALL" -eq 0 ]; then
  echo "(demo-only viewer kernels skipped; run with --all to restore the full manifest.)"
fi
[ "$failed" -eq 0 ]
