#!/usr/bin/env bash
#
# fetch-kernels: reconstitute the SPICE kernels the cosmolabe spice tests need,
# from public archives, verified against sha256. Kernels never enter git (Iron
# rule 7, ADR M-0009); this script serves developers and CI identically and is
# wired ahead of the tests in the root `pnpm verify`.
#
# The checksum manifest below is derived from the LFS pointers captured at merge
# time, filtered to the two kernel directories that M-0009 removed from HEAD:
#
#   git lfs ls-files --long cosmolabe-pre-merge \
#     | grep -E 'test-catalogs/kernels/|spice/test-kernels/'
#
# For an LFS-tracked binary the OID is the sha256, so every download is verified
# against the exact bytes that were removed. Text kernels were plain blobs (not
# LFS); their sha256 here was computed from the same tag and matches NAIF's
# current published copies, so they too download and verify.
#
# Sources, in preference order per kernel:
#   url  public NAIF or PDS URL, the normal path and the one a stranger uses.
#   tag  the cosmolabe-pre-merge git blob (text kernels and the one synthetic
#        test fixture, test_instruments.ti, which has no NAIF home).
#   lfs  the git LFS object, materialized on demand. Used only for de425s.bsp,
#        which NAIF has pruned from its public generic-kernels archive; a single
#        ~9 MB `git lfs fetch` is the minimal-bandwidth fallback (still verified).
#
# A stranger who clones with GIT_LFS_SKIP_SMUDGE=1 gets everything from NAIF/PDS
# except de425s.bsp (one small LFS fetch) and test_instruments.ti (a git blob,
# present in every clone regardless of LFS). Default scope is exactly what the
# spice tests read; `--all` additionally restores the demo-only viewer kernels
# named in the full LFS manifest.
#
# One entry postdates the merge capture: the GS-1 cruise fixture
# 010420R_SCPSE_EP1_JP83.bsp (Session 3, the differential harness of ADR
# M-0002). It was never in Aaron's tree, so its sha256 was computed from the
# NAIF download at the time it was added (2026-07-10) rather than from an LFS
# pointer; it is the smallest reconstructed cruise SCPSE NAIF publishes (8 MB,
# Earth flyby through the post-Jupiter cruise).
#
# Usage: scripts/fetch-kernels [--all] [--force]

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
TAG="cosmolabe-pre-merge"
FETCH_ALL=0
FORCE=0
for arg in "$@"; do
  case "$arg" in
    --all) FETCH_ALL=1 ;;
    --force) FORCE=1 ;;
    -h|--help) grep '^#' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "fetch-kernels: unknown argument: $arg" >&2; exit 2 ;;
  esac
done

cd "$REPO_ROOT"

# ── manifest ─────────────────────────────────────────────────────────────────
# One record per line: dest | sha256 | url | tagpath | lfs | scope
#   dest    repo-relative destination the spice tests read
#   sha256  expected content hash (LFS OID for binaries)
#   url     public NAIF/PDS URL, or '-' if none
#   tagpath path in the cosmolabe-pre-merge tag, or '-' if not in the tag
#   lfs     1 if an LFS object is available as a fallback, else 0
#   scope   test = read by the spice tests (default); demo = viewer-only (--all)

NAIF="https://naif.jpl.nasa.gov/pub/naif"
GEN="$NAIF/generic_kernels"
CAS="$NAIF/CASSINI/kernels"
MSL="$NAIF/MSL/kernels"
CLIPPER="$NAIF/EUROPACLIPPER/kernels"
LRO="$NAIF/LRO/kernels"
LROPDS="$NAIF/pds/data/lro-l-spice-6-v1.0/lrosp_1000/data"

SK="cosmolabe/packages/spice/test-kernels"       # spice unit-test kernels
VK="cosmolabe/apps/viewer/test-catalogs/kernels"  # viewer catalog kernels

