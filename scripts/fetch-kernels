$SK/cassini/010420R_SCPSE_EP1_JP83.bsp|6b91d6bef866ea307f9d778606b62007774eed33bc18b26421f320a8a2dff1fb|$CAS/spk/010420R_SCPSE_EP1_JP83.bsp|-|0|test
$VK/naif0012.tls|678e32bdb5a744117a467cd9601cd6b373f0e9bc9bbde1371d5eee39600a039b|$GEN/lsk/naif0012.tls|apps/viewer/test-catalogs/kernels/naif0012.tls|0|test
$VK/pck00011.tpc|3dff7b1dbeceaa01f25467767d3fa25816051c85d162d1edf04acb310ee28bb1|$GEN/pck/pck00011.tpc|apps/viewer/test-catalogs/kernels/pck00011.tpc|0|test
