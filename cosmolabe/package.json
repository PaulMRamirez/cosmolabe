{
  "name": "cosmolabe",
  "version": "0.0.1",
  "private": true,
  "license": "Apache-2.0",
  "description": "Web mission visualization — SPICE-accurate geometry, TLE tracking, planetary terrain, and a 3D renderer",
  "author": "Aaron Plave",
  "homepage": "https://github.com/AaronPlave/cosmolabe#readme",
  "bugs": "https://github.com/AaronPlave/cosmolabe/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AaronPlave/cosmolabe.git"
  },
  "keywords": [
    "spice",
    "tle",
    "spacecraft",
    "mission-visualization",
    "3d",
    "threejs",
    "cesium",
    "ephemeris",
    "trajectory",
    "astronomy",
    "space"
  ],
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc --build packages/spice packages/core packages/three packages/cesium-adapter packages/cesium",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/ apps/",
    "preprocess:displacement": "node scripts/preprocess-displacement.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "delaunator": "^5.1.0",
    "lightstreamer-client-web": "^9.2.3",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "supportedArchitectures": {
    "os": [
      "darwin",
      "linux"
    ],
    "cpu": [
      "arm64",
      "x64"
    ]
  }
}
