{
  "name": "@cosmolabe/cesium-adapter",
  "version": "0.0.1",
  "private": true,
  "license": "Apache-2.0",
  "description": "Bridge Cosmolabe data into CesiumJS — CZML export, coordinate transforms, time conversions. Standalone (Cesium peer dep is optional).",
  "author": "Aaron Plave",
  "homepage": "https://github.com/AaronPlave/cosmolabe#readme",
  "bugs": "https://github.com/AaronPlave/cosmolabe/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AaronPlave/cosmolabe.git",
    "directory": "packages/cesium-adapter"
  },
  "keywords": [
    "cesium",
    "czml",
    "spice",
    "spacecraft",
    "ephemeris",
    "coordinate-transform",
    "ecliptic",
    "icrf",
    "astronomy",
    "space"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cosmolabe/core": "*"
  },
  "peerDependencies": {
    "cesium": ">=1.100.0"
  },
  "peerDependenciesMeta": {
    "cesium": {
      "optional": true
    }
  }
}
